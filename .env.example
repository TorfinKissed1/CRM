APP_NAME=CRM
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en

# По умолчанию для локального запуска — SQLite (нулевая настройка).
# Для Docker/прод используется Postgres (значения задаются в docker-compose.yml).
DB_CONNECTION=sqlite
# DB_CONNECTION=pgsql
# DB_HOST=db
# DB_PORT=5432
# DB_DATABASE=crm
# DB_USERNAME=crm
# DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# Название бизнеса по умолчанию (переопределяется в Настройках)
CRM_BUSINESS_NAME=CRM
